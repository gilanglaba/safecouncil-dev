# SafeCouncil Backend — Environment Variables
# Copy this file to .env and fill in your API keys

# ============================================================
# AI Provider API Keys (at least one required)
# ============================================================

# Anthropic Claude (Expert A)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI GPT-4o (Expert B)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini (Expert C)
GOOGLE_API_KEY=your_google_api_key_here

# ============================================================
# Server Configuration
# ============================================================

# Port to run on (default: 5000)
PORT=5000

# Host (default: 0.0.0.0 for all interfaces)
HOST=0.0.0.0

# Debug mode (set to false in production)
FLASK_DEBUG=true

# ============================================================
# Model Selection (optional — defaults shown)
# ============================================================

# Anthropic model
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI model
OPENAI_MODEL=gpt-4o

# Google model
GEMINI_MODEL=gemini-1.5-pro

# ============================================================
# Local / On-Premise LLM (LM Studio, Ollama, etc.)
# ============================================================

# Endpoint (LM Studio default: http://127.0.0.1:1234/v1)
LOCAL_ENDPOINT=http://127.0.0.1:1234/v1

# Model name (check LM Studio UI or GET /v1/models)
LOCAL_MODEL=local-model

# API key (LM Studio uses "lm-studio" by default)
LOCAL_API_KEY=lm-studio
