# SafeCouncil Backend — Environment Variables
# Copy this file to .env and fill in your API keys

# ============================================================
# AI Provider API Keys (at least one required)
# ============================================================

# Anthropic Claude (Expert A) — leave empty to run in demo mode
ANTHROPIC_API_KEY=

# OpenAI GPT-4o (Expert B) — leave empty to run in demo mode
OPENAI_API_KEY=

# Google Gemini (Expert C) — leave empty to run in demo mode
GOOGLE_API_KEY=

# ============================================================
# Server Configuration
# ============================================================

# Port to run on (default: 5000)
PORT=5000

# Host (default: 0.0.0.0 for all interfaces)
HOST=0.0.0.0

# Debug mode (set to false in production)
FLASK_DEBUG=true  # enables auto-reload (one restart on startup is normal); set to false for scripted/CI use

# ============================================================
# Model Selection (optional — defaults shown)
# ============================================================

# Anthropic model
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI model
OPENAI_MODEL=gpt-4o

# Google model
GEMINI_MODEL=gemini-2.5-flash

# ============================================================
# Local / On-Premise LLM (LM Studio, Ollama, vLLM, etc.)
# ============================================================
# REQUIRED only if you enable the "local" expert in an evaluation.
# There is no default — point these at your own server.
# If you enable the local expert without these set, the backend will
# return a clear error telling you which variable is missing.

# LOCAL_ENDPOINT=http://localhost:1234/v1
# LOCAL_MODEL=llama-3.1-8b-instruct
# LOCAL_API_KEY=lm-studio

# ============================================================
# Demo Mode
# ============================================================

# DEMO_MODE controls whether the synthesis pipeline runs without LLM calls.
#   true  → force demo mode (always returns a pre-built result, no API keys needed)
#   false → force real mode (fails if no API keys are configured)
#   auto  → automatic: demo mode ONLY when ALL three API keys are missing (default)
#
# IMPORTANT: This is read at backend startup. After editing .env, restart
# the backend with `make dev` to apply changes.
DEMO_MODE=auto
